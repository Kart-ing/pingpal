{
  "name": "@pingpal/faces",
  "version": "0.1.2",
  "description": "Charming ASCII face + message-bubble renderer for PingPal. Pure functions, no I/O.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "demo": "node dist/demo.js",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pingpal/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
